{
	"private": true,
	"name": "web-app",
	"type": "module",
	"version": "1.0.0",
	"description": "Gratheon web application for beehive management. Dual-licensed under AGPL-3.0 (open source) and Commercial License (enterprise). See LICENSE-AGPL and LICENSE-COMMERCIAL.",
	"license": "AGPL",
	"scripts": {
		"prepare": "husky",
		"build-clean": "rm -rf public/*",
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"build-move": "mv dist/* public",
		"serve": "sirv build --cors --single",
		"prettier": "prettier --write --ignore-unknown .",
		"test": "pnpm test:unit",
		"test:unit": "vitest run",
		"test:ui": "vitest --ui",
		"test:e2e:write": "./node_modules/.bin/cypress open",
		"tauri": "tauri"
	},
